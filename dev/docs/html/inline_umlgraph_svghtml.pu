@startuml inline_umlgraph_2.svg
start
:l_idx_u32 = 0;
while (l_idx_u32 < SCHED_NUM_OF_TASKS) is (yes)
  :compute l_timeShift_s32;
  if (l_timeShift_s32 >= 0) then (yes)
    :call handler_();
    :NumOfTaskCalls_au32[idx]++;
  else (no)
  endif
  :l_idx_u32++;
endwhile
:return;
stop
@enduml
@startuml inline_umlgraph_3.svg
start
:Mcu_Initialize();
:Mcu_ServiceWatchdogSow();
:Mcu_ReloadSystick();
stop
@enduml
